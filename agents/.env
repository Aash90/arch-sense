# Server
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite:///./data/arch_sense_game.db

# AI/Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.1-pro-preview

# Game
DIFFICULTY_LEVEL=1
ENABLE_HINTS=true
COACHING_STYLE=aggressive

# CORS
CORS_ORIGIN=http://localhost:5173
